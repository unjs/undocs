{
  "name": "undocs",
  "version": "0.4.16",
  "license": "MIT",
  "repository": "unjs/undocs",
  "bin": {
    "undocs": "./cli/main.mjs"
  },
  "files": [
    "app",
    "cli",
    "schema",
    "!app/**/node_modules",
    "!app/**/tsconfig.json"
  ],
  "type": "module",
  "scripts": {
    "build": "true",
    "dev": "pnpm run docs:dev",
    "docs:build": "pnpm run undocs build docs",
    "docs:dev": "NUXT_DOCS_DEV=1 pnpm run undocs dev docs",
    "lint": "oxlint && oxfmt --check",
    "fmt": "oxlint --fix && oxfmt",
    "prepack": "pnpm run build",
    "profile:0x": "pnpx 0x -o cli/main.mjs dev docs",
    "profile:0x-kernel": "pnpm run profile:0x --kernel-tracing",
    "profile:cpu": "rm -rf .profile && node --cpu-prof --diagnostic-dir ../.profile bin/cli.mjs dev docs",
    "release": "pnpm run lint && changelogen --release && npm publish && git push --follow-tags",
    "template:dev": "pnpm run undocs dev template",
    "undocs": "./cli/main.mjs"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@nuxt/content": "^3.15.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/plausible": "^3.0.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "automd": "^0.4.3",
    "c12": "^4.0.0-beta.5",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "md4w": "^0.2.7",
    "mdream": "^1.4.1",
    "mermaid": "^11.16.0",
    "motion-v": "^2.3.0",
    "nuxi": "^3.36.1",
    "nuxt": "^4.4.8",
    "nuxt-llms": "^0.2.0",
    "pathe": "^2.0.3",
    "scule": "^1.3.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "unctx": "^2.5.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.16.0",
    "@types/node": "^26.1.1",
    "changelogen": "^0.6.2",
    "nitropack": "^2.13.4",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vue-tsc": "^3.3.7"
  },
  "resolutions": {
    "undocs": "link:."
  },
  "packageManager": "pnpm@11.10.0"
}
