{
  "name": "undocs",
  "version": "0.10.0",
  "license": "MIT",
  "repository": "unjs/undocs",
  "bin": {
    "undocs": "./cli/main.mjs"
  },
  "files": [
    "src",
    "cli",
    "schema",
    "nitro.config.ts",
    "vite.config.ts",
    "vite.plugins.ts"
  ],
  "type": "module",
  "exports": {
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "docs:build": "node ./cli/main.mjs build docs",
    "docs:dev": "node ./cli/main.mjs dev docs",
    "lint": "oxlint && oxfmt --check",
    "fmt": "oxlint --fix && oxfmt",
    "profile:0x": "pnpx 0x -o cli/main.mjs dev docs",
    "profile:0x-kernel": "pnpm run profile:0x --kernel-tracing",
    "profile:cpu": "rm -rf .profile && node --cpu-prof --diagnostic-dir ../.profile cli/main.mjs dev docs",
    "release": "pnpm run lint && changelogen --release && npm publish && git push --follow-tags",
    "start": "node docs/.output/server/index.mjs",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "template:dev": "node ./cli/main.mjs dev template",
    "undocs": "./cli/main.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@iconify-json/lucide": "^1.2.118",
    "@iconify-json/vscode-icons": "^1.2.67",
    "@iconify/utils": "^3.1.4",
    "@iconify/vue": "^5.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@unhead/vue": "^3.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vueuse/core": "^14.3.0",
    "automd": "^0.4.3",
    "c12": "^4.0.0-beta.5",
    "citty": "^0.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "md4x": "^0.0.25",
    "mermaid": "^11.16.0",
    "minisearch": "^7.2.0",
    "motion-v": "^2.3.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260722-224121-77b77ffb",
    "ofetch": "^1.5.1",
    "reka-ui": "^2.10.1",
    "scule": "^1.3.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "takumi-js": "^2.4.1",
    "tw-animate-css": "^1.4.0",
    "ufo": "^1.6.4",
    "vite": "latest",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "changelogen": "^0.6.2",
    "oxfmt": ">=0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.15.1"
}
